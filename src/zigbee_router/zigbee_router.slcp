project_name: zigbee_router
label: Zigbee - Router
package: zigbee
category: Zigbee Application
quality: production
description: Zigbee Router firmware optimized for Zigbee2MQTT use. Derived from
  the `zigbee_z4_light` example Simplicity SDK project.
author: Nerivec
sdk:
  vendor: silabs
  id: simplicity_sdk
  version: 2025.12.2
toolchain_settings: []

sdk_extension:
  - id: router_eui64_unique
    vendor: nabucasa
    version: 1.0.0
  - id: router_beacon_filter
    vendor: nabucasa
    version: 1.0.0

component:
  - id: sl_main
    package: simplicity_sdk
    vendor: silabs
  - id: iostream_recommended_stream
    package: simplicity_sdk
    vendor: silabs
  - id: iostream_usart
    package: simplicity_sdk
    vendor: silabs
    instance:
      - vcom
    condition:
      - device_generic_family_efr32xg21
  - id: iostream_eusart
    package: simplicity_sdk
    vendor: silabs
    instance:
      - vcom
    condition:
      - device_has_eusart
  - id: zigbee_debug_basic
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_debug_print
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_pro_stack
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_source_route
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_stack_diagnostics
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_gp
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_zcl_framework_core
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_identify
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_counters
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_green_power_common
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_green_power_client
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_interpan
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_network_steering
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_reporting
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_basic
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_scan_dispatch
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_update_tc_link_key
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_update_app_link_key
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_security_link_keys
    package: simplicity_sdk
    vendor: silabs
  - id: clock_manager
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_dynamic_commissioning
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_trust_center_keepalive
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_poll_control_client
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_bdb_3dot1_rejoin_algorithm
    package: simplicity_sdk
    vendor: silabs
  # - id: zigbee_bdb_3dot1_trust_center_extension
  - id: zigbee_application_bootloader
    package: simplicity_sdk
    vendor: silabs
  # Platform - enable LTO for gcc
  - id: toolchain_gcc_lto
    package: simplicity_sdk
    vendor: silabs
  # custom from zigbee_z4_light & zigbee_gp_z3_light_combo
  - id: rail_util_rssi
    package: simplicity_sdk
    vendor: silabs
  - id: zigbee_concentrator
    package: simplicity_sdk
    vendor: silabs
  - id: router_eui64_unique
    package: router_eui64_unique
    vendor: nabucasa
  - id: router_beacon_filter
    package: router_beacon_filter
    vendor: nabucasa

define:
  # - name: SL_ZIGBEE_CUSTOM_MAC_FILTER_TABLE_SIZE
  #   value: 15
  - name: SL_ZIGBEE_MULTICAST_TABLE_SIZE
    value: 26
  ## xg21
  - name: SL_ZIGBEE_ROUTE_TABLE_SIZE
    value: 200
    condition: [ "device_generic_family_efr32xg21" ]
  ## xg24
  - name: SL_ZIGBEE_ROUTE_TABLE_SIZE
    value: 254
    condition: [ "device_generic_family_efr32xg24" ]
  ## xg26
  - name: SL_ZIGBEE_ROUTE_TABLE_SIZE
    value: 254
    condition: [ "device_generic_family_efr32xg26" ]
  - name: SL_ZIGBEE_DISCOVERY_TABLE_SIZE
    value: 16

configuration:
  - name: SL_BOARD_ENABLE_VCOM
    value: 1
  - name: SL_IOSTREAM_USART_VCOM_FLOW_CONTROL_TYPE
    value: usartHwFlowControlCtsAndRts
    condition:
      - iostream_usart
  - name: SL_IOSTREAM_EUSART_VCOM_FLOW_CONTROL_TYPE
    value: SL_IOSTREAM_EUSART_UART_FLOW_CTRL_CTS_RTS
    condition:
      - iostream_eusart
  - name: SL_CLI_MAX_INPUT_ARGUMENTS
    value: 16
  - name: SLI_ZIGBEE_PRIMARY_NETWORK_DEVICE_TYPE
    value: SLI_ZIGBEE_NETWORK_DEVICE_TYPE_ROUTER
  - name: SLI_ZIGBEE_PRIMARY_NETWORK_SECURITY_TYPE
    value: SLI_ZIGBEE_NETWORK_SECURITY_TYPE_4_0
  - name: SL_CLI_PROMPT_STRING
    value: "\"zigbee_router>\""
  - name: NVM3_DEFAULT_NVM_SIZE
    value: 32768
    condition:
      - device_series_2
  # If using zigbee_secure_key_storage we do not need to support backwards
  # compatibility because we have never deployed images with keys in PSA
  # As a result, these lines end up saving some code space
  - name: SL_PSA_ITS_SUPPORT_V1_DRIVER
    value: 0
  - name: SL_PSA_ITS_SUPPORT_V2_DRIVER
    value: 0
  - name: SL_PSA_ITS_SUPPORT_V3_DRIVER
    value: 1
  - name: SL_STACK_SIZE
    value: 1024
    condition:
      - freertos
      - device_series_2
  - name: SL_STACK_SIZE
    value: 16384
    condition:
      - device_series_3
  - name: SL_STACK_SIZE
    value: 512
    condition:
      - micriumos_kernel
      - device_series_2
  # Timer RTOS task priority needs to be one more than SL_BT_RTOS_LINK_LAYER_TASK_PRIORITY
  # BT uses event flags that require the timer task to be higher priority than all other RTOS tasks
  - name: configTIMER_TASK_PRIORITY
    value: 53
  - name: configMAX_TASK_NAME_LEN
    value: 30
  - name: SL_CLI_EXAMPLE_TASK_STACK_SIZE
    value: 600
    condition:
      - cmsis_rtos2
  # On series 3, the bootloader requires more stack to do context parsing of OTA images
  - name: SL_CLI_EXAMPLE_TASK_STACK_SIZE
    value: 1500
    condition:
      - device_series_3
  - name: SL_ZIGBEE_STACK_RTOS_TASK_STACK_SIZE
    value: 5800
    condition:
      - device_series_3
  - name: SL_ZIGBEE_APP_FRAMEWORK_RTOS_TASK_STACK_SIZE
    value: 6000
    condition:
      - device_series_3
  # On series 3, IPC for big hdr phy packets requires bigger stack sizes
  - name: SL_CLI_EXAMPLE_TASK_STACK_SIZE
    value: 1500
    condition:
      - zigbee_high_datarate_phy
      - device_series_3
  - name: SL_ZIGBEE_STACK_RTOS_TASK_STACK_SIZE
    value: 5800
    condition:
      - zigbee_high_datarate_phy
      - device_series_3
  - name: SL_ZIGBEE_APP_FRAMEWORK_RTOS_TASK_STACK_SIZE
    value: 6000
    condition:
      - zigbee_high_datarate_phy
      - device_series_3
  - name: SL_HDR_PHY_MAX_PACKET_SIZE
    value: 2045
    condition:
      - zigbee_high_datarate_phy
      - device_series_3
  - name: SL_ZIGBEE_AF_PLUGIN_ZCL_CLUSTER_DEFER_ATTRIBUTE_WRITES_TO_NVM_MS
    value: 2000
    condition:
      - device_series_3
  - name: SL_ZIGBEE_AF_PLUGIN_NETWORK_STEERING_ENABLE_AUTOSTART
    value: 0
  - name: SL_ZIGBEE_AF_PLUGIN_TRUST_CENTER_KEEPALIVE_DEFAULT_BASE_PERIOD_MINUTES
    value: 1
  - name: SL_ZIGBEE_AF_PLUGIN_TRUST_CENTER_KEEPALIVE_DEFAULT_JITTER_PERIOD_SECONDS
    value: 30
  # custom from zigbee_z3_light & zigbee_gp_z3_light_combo
  - name: SL_IOSTREAM_USART_VCOM_RX_BUFFER_SIZE
    value: 64
    condition:
      - iostream_usart
  - name: SL_IOSTREAM_EUSART_VCOM_RX_BUFFER_SIZE
    value: 64
    condition:
      - iostream_eusart
  - name: SL_ZIGBEE_BROADCAST_TABLE_SIZE
    value: 30
  - name: SL_ZIGBEE_NEIGHBOR_TABLE_SIZE
    value: 26
  - name: SL_ZIGBEE_BINDING_TABLE_SIZE
    value: 32
  - name: SL_ZIGBEE_GP_PROXY_TABLE_SIZE
    value: 10
  - name: SL_ZIGBEE_KEY_TABLE_SIZE
    value: 1
  - name: SL_ZIGBEE_SOURCE_ROUTE_TABLE_SIZE
    value: 254
  - name: SL_ZIGBEE_AF_PLUGIN_NETWORK_STEERING_CHANNEL_MASK
    value: 0x7fff800 # all zigbee channels
  - name: SL_ZIGBEE_AF_PLUGIN_NETWORK_STEERING_RADIO_TX_POWER
    value: 19
  - name: SL_ZIGBEE_AF_PLUGIN_CONCENTRATOR_CONCENTRATOR_TYPE
    value: HIGH_RAM_CONCENTRATOR
  - name: SL_ZIGBEE_AF_PLUGIN_CONCENTRATOR_MIN_TIME_BETWEEN_BROADCASTS_SECONDS
    value: 30 # <1-60>
  - name: SL_ZIGBEE_AF_PLUGIN_CONCENTRATOR_MAX_TIME_BETWEEN_BROADCASTS_SECONDS
    value: 180 # <30-300>
  - name: SL_ZIGBEE_AF_PLUGIN_CONCENTRATOR_ROUTE_ERROR_THRESHOLD
    value: 3 # <1-100>
  - name: SL_ZIGBEE_AF_PLUGIN_CONCENTRATOR_DELIVERY_FAILURE_THRESHOLD
    value: 1 # <1-100>
  ## xg21
  - name: SL_ZIGBEE_ADDRESS_TABLE_SIZE
    value: 32
    condition: [ "device_generic_family_efr32xg21" ]
  - name: SL_ZIGBEE_APS_UNICAST_MESSAGE_COUNT
    value: 64
    condition: [ "device_generic_family_efr32xg21" ]
  - name: SL_ZIGBEE_MAX_END_DEVICE_CHILDREN
    value: 32
    condition: [ "device_generic_family_efr32xg21" ]
  ## xg24
  - name: SL_ZIGBEE_ADDRESS_TABLE_SIZE
    value: 128
    condition: [ "device_generic_family_efr32xg24" ]
  - name: SL_ZIGBEE_APS_UNICAST_MESSAGE_COUNT
    value: 128
    condition: [ "device_generic_family_efr32xg24" ]
  - name: SL_ZIGBEE_MAX_END_DEVICE_CHILDREN
    value: 64
    condition: [ "device_generic_family_efr32xg24" ]
  - name: SL_ZIGBEE_APS_DUPLICATE_REJECTION_MAX_ENTRIES
    value: 64
    condition: [ "device_generic_family_efr32xg24" ]
  ## xg26
  - name: SL_ZIGBEE_ADDRESS_TABLE_SIZE
    value: 128
    condition: [ "device_generic_family_efr32xg26" ]
  - name: SL_ZIGBEE_APS_UNICAST_MESSAGE_COUNT
    value: 128
    condition: [ "device_generic_family_efr32xg26" ]
  - name: SL_ZIGBEE_MAX_END_DEVICE_CHILDREN
    value: 64
    condition: [ "device_generic_family_efr32xg26" ]
  - name: SL_ZIGBEE_APS_DUPLICATE_REJECTION_MAX_ENTRIES
    value: 64
    condition: [ "device_generic_family_efr32xg26" ]

source:
  - path: main.c
  - path: app.c

config_file:
  - path: config/zcl/zcl_config.zap
    directory: zcl

# Use CUSTOM_TOKEN_HEADER macro to point to custom token definitions (optional)
# - name: "CUSTOM_TOKEN_HEADER"
#    value: "\"example_custom_tokens.h\""

# Use CUSTOM_MFG_TOKEN_HEADER macro to point to custom manufacturing token
# definitions (optional)
# - name: "CUSTOM_MFG_TOKEN_HEADER"
#    value: "\"example_custom_mfg_tokens.h\""

filter:
  - name: Wireless Technology
    value: [ Zigbee ]
  - name: Device Type
    value: [ SoC ]
  - name: Project Difficulty
    value: [ Beginner ]
